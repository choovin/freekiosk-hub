package main

import "github.com/wared2003/freekiosk-hub/ui"

templ PushNotificationPage(props interface{}) {
	<div class="min-h-screen bg-gray-100">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
			<div class="mb-6">
				<h1 class="text-2xl font-bold text-gray-900">推送通知</h1>
				<p class="mt-1 text-sm text-gray-500">向设备发送实时通知和警报</p>
			</div>
		</div>
	</div>
}
