# FreeKiosk Hub Configuration
# Copy this file to .env and fill in your values

# -- Server Configuration --
SERVER_PORT=8081
LOG_LEVEL=INFO

# -- Database --
# DB_PATH is set to /app/data/freekiosk.db in docker-compose.yml

# -- Kiosk Communication --
KIOSK_PORT=8080
KIOSK_API_KEY=your-secret-api-key-here

# -- Tailscale Integration (Required) --
# Create an API key from the Tailscale admin console:
# https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=tskey-auth-your-key-here

# -- MQTT Configuration (EMQX 5.0+) --
# MQTT Broker 地址
MQTT_BROKER_URL=localhost
# MQTT Broker 端口 (1883 为非加密端口, 8883 为 TLS 端口)
MQTT_PORT=1883
# 客户端 ID (建议使用主机名或唯一标识)
MQTT_CLIENT_ID=freekiosk-hub
# MQTT 认证用户名 (可选, 如 EMQX 配置了认证)
# MQTT_USERNAME=
# MQTT 认证密码 (可选, 如 EMQX 配置了认证)
# MQTT_PASSWORD=
# 是否使用 TLS 连接
MQTT_USE_TLS=false
# 心跳间隔
MQTT_KEEPALIVE=60s
# 是否清除会话 (建议 false 以保持会话持久化)
MQTT_CLEAN_START=false

# -- Performance --
POLL_INTERVAL=30s
RETENTION_DAYS=31
MAX_WORKERS=5

# -- Media --
BASE_URL=http://localhost:8081
